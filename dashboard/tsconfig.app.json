{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2021",
    "module": "esnext",
    "types": ["svelte", "vite/client"],
    "composite": true,
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "baseUrl": ".",
    // "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte", "src/**/*.tsx", "src/**/*.jsx"]
}
